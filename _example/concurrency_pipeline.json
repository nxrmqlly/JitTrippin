{
    "name": "Concurrency Test",
    "description": "Tests Kahn scheduler + worker pool",
    "jobs": [
        {
            "name": "setup",
            "image": "alpine:latest",
            "steps": [
                {
                    "name": "setup",
                    "cmd": "echo '[setup] start'; sleep 2; echo '[setup] done'"
                }
            ]
        },
        {
            "name": "lint",
            "image": "alpine:latest",
            "depends_on": [
                "setup"
            ],
            "steps": [
                {
                    "name": "lint",
                    "cmd": "echo '[lint] start'; sleep 5; echo '[lint] done'"
                }
            ]
        },
        {
            "name": "build-linux",
            "image": "alpine:latest",
            "depends_on": [
                "setup"
            ],
            "steps": [
                {
                    "name": "linux",
                    "cmd": "echo '[linux] compiling'; sleep 3; echo '[linux] done'"
                }
            ]
        },
        {
            "name": "build-windows",
            "image": "alpine:latest",
            "depends_on": [
                "setup"
            ],
            "steps": [
                {
                    "name": "windows",
                    "cmd": "echo '[windows] compiling'; sleep 4; echo '[windows] done'"
                }
            ]
        },
        {
            "name": "unit-tests",
            "image": "alpine:latest",
            "depends_on": [
                "build-linux"
            ],
            "steps": [
                {
                    "name": "tests",
                    "cmd": "echo '[tests] running'; sleep 2; echo '[tests] done'"
                }
            ]
        },
        {
            "name": "package",
            "image": "alpine:latest",
            "depends_on": [
                "lint",
                "build-windows",
                "unit-tests"
            ],
            "steps": [
                {
                    "name": "package",
                    "cmd": "echo '[package] creating artifact'; sleep 1; echo '[package] done'"
                }
            ]
        },
        {
            "name": "deploy",
            "image": "alpine:latest",
            "depends_on": [
                "package"
            ],
            "steps": [
                {
                    "name": "deploy",
                    "cmd": "echo '[deploy] deploying'; sleep 2; echo '[deploy] success'"
                }
            ]
        }
    ]
}