{
    "name": "JitTrippin Chaos Monkey Pipeline",
    "description": "#aislop_is_funny #australia",
    "jobs": [
        {
            "name": "setup-and-verify",
            "image": "alpine:latest",
            "env": {
                "APP_ENVIRONMENT": "local-sandbox",
                "BUILD_USER": "nxrmqlly"
            },
            "depends_on": [],
            "steps": [
                {
                    "name": "Who Am I",
                    "cmd": "whoami"
                },
                {
                    "name": "Check Env Varz",
                    "cmd": "echo \"Environment is set to: $APP_ENVIRONMENT by $BUILD_USER\""
                },
                {
                    "name": "Simulate Work",
                    "cmd": "echo 'Installing dummy tool...' && sleep 3 && echo 'Done!'"
                }
            ]
        },
        {
            "name": "faulty-verification-job",
            "image": "alpine:latest",
            "env": {},
            "depends_on": [
                "setup-and-verify"
            ],
            "steps": [
                {
                    "name": "Healthy Pre-check",
                    "cmd": "echo 'Running sanity checks before exploding...'"
                },
                {
                    "name": "Intentional Failure",
                    "cmd": "echo 'Oh no, missing critical file!' >&2 && exit 1"
                },
                {
                    "name": "Skipped Step",
                    "cmd": "echo 'This step should never execute because the previous one errored out.'"
                }
            ]
        }
    ]
}