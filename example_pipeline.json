{
    "name": "Linear Scheduler Test",
    "description": "Exercises dependency ordering.",
    "jobs": [
        {
            "name": "setup",
            "image": "alpine:latest",
            "depends_on": [],
            "steps": [
                {
                    "name": "start",
                    "cmd": "echo '[setup] starting' && sleep 2"
                },
                {
                    "name": "finish",
                    "cmd": "echo '[setup] done'"
                }
            ]
        },
        {
            "name": "lint",
            "image": "alpine:latest",
            "depends_on": [
                "setup"
            ],
            "steps": [
                {
                    "name": "lint",
                    "cmd": "echo '[lint] running' && sleep 1 && echo '[lint] passed'"
                }
            ]
        },
        {
            "name": "build",
            "image": "alpine:latest",
            "depends_on": [
                "setup"
            ],
            "steps": [
                {
                    "name": "build",
                    "cmd": "echo '[build] compiling' && sleep 3 && echo '[build] complete'"
                }
            ]
        },
        {
            "name": "test",
            "image": "alpine:latest",
            "depends_on": [
                "build"
            ],
            "steps": [
                {
                    "name": "test",
                    "cmd": "echo '[test] executing tests' && sleep 2 && echo '[test] passed'"
                }
            ]
        },
        {
            "name": "package",
            "image": "alpine:latest",
            "depends_on": [
                "build"
            ],
            "steps": [
                {
                    "name": "package",
                    "cmd": "echo '[package] creating artifact' && sleep 1 && echo '[package] artifact ready'"
                }
            ]
        },
        {
            "name": "deploy",
            "image": "alpine:latest",
            "depends_on": [
                "lint",
                "test",
                "package"
            ],
            "steps": [
                {
                    "name": "deploy",
                    "cmd": "echo '[deploy] deploying...' && sleep 2 && echo '[deploy] success'"
                }
            ]
        }
    ]
}